PORT=3001

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper trascrizione vocale)
OPENAI_API_KEY=sk-...

# Microsoft Outlook Calendar Integration
MICROSOFT_CLIENT_ID=xxxxx
MICROSOFT_CLIENT_SECRET=xxxxx
MICROSOFT_TENANT=xxxxx (oppure "common")
MICROSOFT_REDIRECT_URI=https://tuodominio.com/api/outlook/callback

# SMTP per email reminder (Outlook aziendale)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=nome@tuaazienda.com
SMTP_PASS=password_outlook

# Cron schedule reminder (default: ogni giorno alle 8:00)
# Formato cron standard. Es: "0 8 * * *" = ogni giorno 8:00, "0 8 */2 * *" = ogni 2 giorni
REMINDER_CRON=0 8 * * *

# Frontend URL (per redirect OAuth e link nelle email)
FRONTEND_URL=https://tuodominio.com

# Origini permesse
ALLOWED_ORIGINS=http://localhost:3001,https://tuodominio.com

# Environment
NODE_ENV=production

